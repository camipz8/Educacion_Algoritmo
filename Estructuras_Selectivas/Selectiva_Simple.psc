Algoritmo Selectivo_Simple
	//Averiuar el mayor de dos números
	Definir num1, num2 Como Caracter;
	Escribir "Ingrese el primer numero:";
	Leer num1;
	Escribir "Ingrese el segundo numero:";
	Leer num2;
	Si num1>num2 Entonces
		Escribir "El primer numero es mayor que el segundo";
	FinSi
	Si num2>num1 Entonces
		Escribir "El segundo numero es mayor que el segundo";
	FinSi
FinAlgoritmo
